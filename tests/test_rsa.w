        0x8Bu8, 0xB3u8, 0x15u8, 0xC7u8, 0xBCu8, 0x9Du8, 0x3Au8, 0x48u8,
        0x0Fu8, 0x34u8, 0x8Du8, 0x22u8, 0x3Cu8, 0x3Au8, 0x3Bu8, 0x05u8,
        0x2Bu8, 0xB2u8, 0x37u8, 0x7Au8, 0xA4u8, 0xD8u8, 0xC8u8, 0xD8u8,
        0x77u8, 0x35u8, 0x57u8, 0x8Bu8, 0x9Au8, 0x92u8, 0xBCu8, 0x79u8,
        0xCAu8, 0x78u8, 0x19u8, 0x4Du8, 0x09u8, 0x1Au8, 0x60u8, 0xC9u8,
        0x87u8, 0xE1u8, 0x94u8, 0x63u8, 0xEDu8, 0x36u8, 0x7Fu8, 0x8Cu8,
        0x58u8, 0x07u8, 0x2Bu8, 0x2Au8, 0xF3u8, 0x63u8, 0x0Bu8, 0xB2u8,
        0xEEu8, 0x1Au8, 0xA8u8, 0x69u8, 0x31u8, 0xFCu8, 0x91u8, 0x41u8,
        0xC3u8, 0x3Cu8, 0x3Au8, 0x80u8, 0x67u8, 0x97u8, 0xA2u8, 0x59u8,
    ]
    // e = 65537 = 0x010001
    var e: [u8; 3] = [0x01u8, 0x00u8, 0x01u8]

    var sig: [u8; 128] = [
        0x7Fu8, 0x54u8, 0x49u8, 0x80u8, 0xEAu8, 0x5Du8, 0xAEu8, 0xA0u8,
        0x37u8, 0x39u8, 0x43u8, 0x60u8, 0x9Eu8, 0xF1u8, 0xC0u8, 0x67u8,
        0x0Bu8, 0x6Fu8, 0xF2u8, 0xA8u8, 0xCFu8, 0x32u8, 0xC3u8, 0x40u8,
        0x37u8, 0x5Eu8, 0xBFu8, 0xAAu8, 0x09u8, 0xFBu8, 0x6Au8, 0x6Au8,
        0x87u8, 0x60u8, 0x1Eu8, 0x1Eu8, 0xBAu8, 0xBAu8, 0xE7u8, 0x24u8,
        0xF7u8, 0xA6u8, 0x8Eu8, 0xC3u8, 0xB2u8, 0xDEu8, 0x36u8, 0x6Eu8,
        0x78u8, 0x52u8, 0xB4u8, 0x0Du8, 0x5Bu8, 0xACu8, 0xF6u8, 0x30u8,
        0x2Au8, 0x0Bu8, 0x06u8, 0xE5u8, 0x8Du8, 0xB5u8, 0x28u8, 0x34u8,
        0x09u8, 0x57u8, 0xCEu8, 0x73u8, 0x81u8, 0x5Fu8, 0xF2u8, 0x77u8,
        0x24u8, 0x55u8, 0x7Bu8, 0xC3u8, 0xB4u8, 0x29u8, 0x6Au8, 0xDEu8,
        0x39u8, 0xE0u8, 0xCAu8, 0x86u8, 0x27u8, 0xEAu8, 0x27u8, 0x0Cu8,
        0x09u8, 0x29u8, 0x9Du8, 0xCBu8, 0xEBu8, 0x82u8, 0x94u8, 0xDAu8,
        0xABu8, 0xE6u8, 0x41u8, 0x48u8, 0x59u8, 0xE1u8, 0xD7u8, 0x21u8,
        0xE3u8, 0x7Fu8, 0xB2u8, 0x64u8, 0xB9u8, 0x8Eu8, 0x54u8, 0xCCu8,
        0xEDu8, 0xB6u8, 0x36u8, 0x3Fu8, 0x51u8, 0xCFu8, 0x37u8, 0x94u8,
        0xB9u8, 0xC3u8, 0xABu8, 0x39u8, 0xFBu8, 0x2Eu8, 0x67u8, 0x12u8,
    ]

    // SHA-256("test")
    var hash: [u8; 32] = [
        0x9Fu8, 0x86u8, 0xD0u8, 0x81u8, 0x88u8, 0x4Cu8, 0x7Du8, 0x65u8,
        0x9Au8, 0x2Fu8, 0xEAu8, 0xA0u8, 0xC5u8, 0x5Au8, 0xD0u8, 0x15u8,
        0xA3u8, 0xBFu8, 0x4Fu8, 0x1Bu8, 0x2Bu8, 0x0Bu8, 0x82u8, 0x2Cu8,
        0xD1u8, 0x5Du8, 0x6Cu8, 0x15u8, 0xB0u8, 0xF0u8, 0x0Au8, 0x08u8,
    ]

    let r = unsafe: rsa_pkcs1_sha256_verify(
        &n[0] as *const u8, 128,
        &e[0] as *const u8, 3,
        &sig[0] as *const u8, 128,
        &hash[0] as *const u8,
    )
    assert_true(r == 1, "RSA-1024 SHA-256 verify")

    // Corrupt signature → should fail
    sig[0] = sig[0] ^ 0x01u8
    let r2 = unsafe: rsa_pkcs1_sha256_verify(
        &n[0] as *const u8, 128,
        &e[0] as *const u8, 3,
        &sig[0] as *const u8, 128,
        &hash[0] as *const u8,
    )
    assert_true(r2 == 0, "corrupted sig rejected")

fn main:
    with_eprintln("=== RSA Test Suite ===")
    test_pkcs1_padding()
    test_rsa_verify()
    with_eprintln("=== Results: " ++ int_to_string(pass_count) ++ "/" ++ int_to_string(test_count) ++ " passed ===")
    if fail_count > 0:
        with_eprintln("FAILURES: " ++ int_to_string(fail_count))
    else:
        with_eprintln("ALL PASSED")
