// test_rsa.w — RSA PKCS#1 v1.5 signature verification test

use std.crypto.rsa

extern fn with_eprintln(s: str) -> void
extern fn int_to_string(n: i32) -> str

var test_count: i32 = 0
var pass_count: i32 = 0
var fail_count: i32 = 0

fn assert_true(cond: bool, msg: str):
    test_count = test_count + 1
    if cond:
        pass_count = pass_count + 1
    else:
        fail_count = fail_count + 1
        with_eprintln("  FAIL: " ++ msg)

// ── PKCS#1 padding check ───────────────────────────────────────────

fn test_pkcs1_padding:
    with_eprintln("  pkcs1 padding check...")
    // Manually constructed valid EM block (128 bytes) for SHA-256("test")
    var em: [u8; 128] = [
        0x00u8, 0x01u8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0x00u8, 0x30u8, 0x31u8, 0x30u8,
        0x0Du8, 0x06u8, 0x09u8, 0x60u8, 0x86u8, 0x48u8, 0x01u8, 0x65u8,
        0x03u8, 0x04u8, 0x02u8, 0x01u8, 0x05u8, 0x00u8, 0x04u8, 0x20u8,
        0x9Fu8, 0x86u8, 0xD0u8, 0x81u8, 0x88u8, 0x4Cu8, 0x7Du8, 0x65u8,
        0x9Au8, 0x2Fu8, 0xEAu8, 0xA0u8, 0xC5u8, 0x5Au8, 0xD0u8, 0x15u8,
        0xA3u8, 0xBFu8, 0x4Fu8, 0x1Bu8, 0x2Bu8, 0x0Bu8, 0x82u8, 0x2Cu8,
        0xD1u8, 0x5Du8, 0x6Cu8, 0x15u8, 0xB0u8, 0xF0u8, 0x0Au8, 0x08u8,
    ]
    // SHA-256("test")
    var hash: [u8; 32] = [
        0x9Fu8, 0x86u8, 0xD0u8, 0x81u8, 0x88u8, 0x4Cu8, 0x7Du8, 0x65u8,
        0x9Au8, 0x2Fu8, 0xEAu8, 0xA0u8, 0xC5u8, 0x5Au8, 0xD0u8, 0x15u8,
        0xA3u8, 0xBFu8, 0x4Fu8, 0x1Bu8, 0x2Bu8, 0x0Bu8, 0x82u8, 0x2Cu8,
        0xD1u8, 0x5Du8, 0x6Cu8, 0x15u8, 0xB0u8, 0xF0u8, 0x0Au8, 0x08u8,
    ]

    let r = unsafe: rsa_check_pkcs1_sha256(&em[0] as *const u8, 128, &hash[0] as *const u8)
    assert_true(r == 1, "valid PKCS1 padding accepted")

    // Corrupt one hash byte → should fail
    em[127] = 0x00u8
    let r2 = unsafe: rsa_check_pkcs1_sha256(&em[0] as *const u8, 128, &hash[0] as *const u8)
    assert_true(r2 == 0, "corrupted hash rejected")

    // Restore hash, corrupt padding → should fail
    em[127] = 0x08u8
    em[10] = 0x00u8  // break an 0xFF byte
    let r3 = unsafe: rsa_check_pkcs1_sha256(&em[0] as *const u8, 128, &hash[0] as *const u8)
    assert_true(r3 == 0, "corrupted padding rejected")

// ── Full RSA-1024 signature verification ───────────────────────────

fn test_rsa_verify:
    with_eprintln("  RSA-1024 verify...")
    var n: [u8; 128] = [
        0xCEu8, 0xCFu8, 0xD4u8, 0x8Fu8, 0x9Bu8, 0x4Fu8, 0xA3u8, 0x8Cu8,
        0xADu8, 0xCBu8, 0x40u8, 0x7Bu8, 0x29u8, 0x87u8, 0x6Bu8, 0x39u8,
        0xF4u8, 0xD6u8, 0x79u8, 0x8Du8, 0xD8u8, 0x0Cu8, 0xEDu8, 0xB5u8,
        0x9Du8, 0x75u8, 0x31u8, 0xAFu8, 0x36u8, 0x0Cu8, 0xD3u8, 0xACu8,
        0x76u8, 0xE4u8, 0x27u8, 0x59u8, 0x3Bu8, 0x7Bu8, 0xD0u8, 0x89u8,
