//! expect-stdout: 5000
//! expect-stdout: content ok

// String constants longer than the LLVM bridge cstr slot (4096) must be
// emitted intact: length-aware emission, not to_cstr truncation (#557).
fn main:
    let s = ""
    print(f"{s.len()}")
    if s.byte_at(4500) == 65 and s.byte_at(4999) == 90:
        print("content ok")
    else:
        print("content corrupt")
