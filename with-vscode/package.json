{
  "name": "with-lang",
  "displayName": "With",
  "description": "With language support — syntax highlighting, diagnostics, go-to-definition, hover",
  "version": "0.1.0",
  "publisher": "quixiai",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuixiAI/with"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:with"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "with",
      "aliases": ["With", "with"],
      "extensions": [".w"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "with",
      "scopeName": "source.with",
      "path": "./syntaxes/with.tmLanguage.json"
    }],
    "configuration": {
      "title": "With",
      "properties": {
        "with.lsp.path": {
          "type": "string",
          "default": "with",
          "description": "Path to the with binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
