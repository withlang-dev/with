; ModuleID = '<with_module>'
source_filename = "<source>"
target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-n32:64-S128-Fn32"
target triple = "arm64-apple-darwin25.2.0"

%Circle = type { i32 }
%Square = type { i32 }

@__vtable_Circle_Describable = internal constant { ptr } { ptr @__dynwrap_Circle_describe }
@__vtable_Square_Describable = internal constant { ptr } { ptr @__dynwrap_Square_describe }

define i32 @Circle.describe(ptr %0) {
entry:
  %1 = alloca ptr, align 8
  store ptr %0, ptr %1, align 8
  %ptr = load ptr, ptr %1, align 8
  %2 = getelementptr inbounds nuw %Circle, ptr %ptr, i32 0, i32 0
  %ptr.field = load i32, ptr %2, align 4
  ret i32 %ptr.field
}

define i32 @Square.describe(ptr %0) {
entry:
  %1 = alloca ptr, align 8
  store ptr %0, ptr %1, align 8
  %ptr = load ptr, ptr %1, align 8
  %2 = getelementptr inbounds nuw %Square, ptr %ptr, i32 0, i32 0
  %ptr.field = load i32, ptr %2, align 4
  ret i32 %ptr.field
}

define i32 @get_value({ ptr, ptr } %0) {
entry:
  %1 = alloca { ptr, ptr }, align 8
  store { ptr, ptr } %0, ptr %1, align 8
  %2 = load { ptr, ptr }, ptr %1, align 8
  %dyn.data = extractvalue { ptr, ptr } %2, 0
  %dyn.vtable = extractvalue { ptr, ptr } %2, 1
  %vtable.gep = getelementptr { ptr }, ptr %dyn.vtable, i32 0, i32 0
  %vtable.fn = load ptr, ptr %vtable.gep, align 8
  %dyncall = call i32 %vtable.fn(ptr %dyn.data)
  ret i32 %dyncall
}

define i32 @main() {
entry:
  %struct = alloca %Circle, align 8
  %0 = getelementptr inbounds nuw %Circle, ptr %struct, i32 0, i32 0
  store i32 5, ptr %0, align 4
  %struct.val = load %Circle, ptr %struct, align 4
  %1 = alloca %Circle, align 8
  store %Circle %struct.val, ptr %1, align 4
  %struct1 = alloca %Square, align 8
  %2 = getelementptr inbounds nuw %Square, ptr %struct1, i32 0, i32 0
  store i32 10, ptr %2, align 4
  %struct.val2 = load %Square, ptr %struct1, align 4
  %3 = alloca %Square, align 8
  store %Square %struct.val2, ptr %3, align 4
  %4 = load %Circle, ptr %1, align 4
  %dyn.data = alloca %Circle, align 8
  store %Circle %4, ptr %dyn.data, align 4
  %dyn.withdata = insertvalue { ptr, ptr } undef, ptr %dyn.data, 0
  %dyn.withvtable = insertvalue { ptr, ptr } %dyn.withdata, ptr @__vtable_Circle_Describable, 1
  %call = call i32 @get_value({ ptr, ptr } %dyn.withvtable)
  %eq = icmp eq i32 %call, 5
  br i1 %eq, label %assert.ok, label %assert.fail

assert.fail:                                      ; preds = %entry
  call void @_exit(i32 134)
  unreachable

assert.ok:                                        ; preds = %entry
  %5 = load %Square, ptr %3, align 4
  %dyn.data3 = alloca %Square, align 8
  store %Square %5, ptr %dyn.data3, align 4
  %dyn.withdata4 = insertvalue { ptr, ptr } undef, ptr %dyn.data3, 0
  %dyn.withvtable5 = insertvalue { ptr, ptr } %dyn.withdata4, ptr @__vtable_Square_Describable, 1
  %call6 = call i32 @get_value({ ptr, ptr } %dyn.withvtable5)
  %eq7 = icmp eq i32 %call6, 10
  br i1 %eq7, label %assert.ok9, label %assert.fail8

assert.fail8:                                     ; preds = %assert.ok
  call void @_exit(i32 134)
  unreachable

assert.ok9:                                       ; preds = %assert.ok
  ret i32 0
}

define internal i32 @__dynwrap_Circle_describe(ptr %0) {
entry:
  %res = call i32 @Circle.describe(ptr %0)
  ret i32 %res
}

define internal i32 @__dynwrap_Square_describe(ptr %0) {
entry:
  %res = call i32 @Square.describe(ptr %0)
  ret i32 %res
}

declare void @_exit(i32)

