---
trait Describable =
    fn describe(self: Self) -> i32

type Circle = { radius: i32 }
type Square = { side: i32 }
fn Circle.describe(self: Circle) -> i32:
  self.radius
impl Describable for Circle
fn Square.describe(self: Square) -> i32:
  self.side
impl Describable for Square
fn get_value(obj: dyn Describable) -> i32:
  obj.describe()
fn main -> i32:
  let c = Circle { radius: 5 }
  let s = Square { side: 10 }
  assert((get_value(c) == 5))
  assert((get_value(s) == 10))
