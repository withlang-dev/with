; ModuleID = '<with_module>'
source_filename = "<source>"
target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-n32:64-S128-Fn32"
target triple = "arm64-apple-darwin25.2.0"

@overflow.msg = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1
@overflow.msg.1 = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1
@fmt = private unnamed_addr constant [3 x i8] c"%d\00", align 1
@nl = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@overflow.msg.2 = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1
@overflow.msg.3 = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1
@fmt.4 = private unnamed_addr constant [3 x i8] c"%d\00", align 1
@nl.5 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@overflow.msg.6 = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1
@fmt.7 = private unnamed_addr constant [3 x i8] c"%d\00", align 1
@nl.8 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@fmt.9 = private unnamed_addr constant [3 x i8] c"%d\00", align 1
@nl.10 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1

define i32 @main() {
entry:
  %0 = call { i32, i1 } @llvm.smul.with.overflow.i32(i32 3, i32 4)
  %mul = extractvalue { i32, i1 } %0, 0
  %overflow = extractvalue { i32, i1 } %0, 1
  br i1 %overflow, label %overflow.trap, label %overflow.ok

overflow.trap:                                    ; preds = %entry
  %1 = call i32 @write(i32 2, ptr @overflow.msg, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok:                                      ; preds = %entry
  %2 = call { i32, i1 } @llvm.sadd.with.overflow.i32(i32 2, i32 %mul)
  %add = extractvalue { i32, i1 } %2, 0
  %overflow1 = extractvalue { i32, i1 } %2, 1
  br i1 %overflow1, label %overflow.trap2, label %overflow.ok3

overflow.trap2:                                   ; preds = %overflow.ok
  %3 = call i32 @write(i32 2, ptr @overflow.msg.1, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok3:                                     ; preds = %overflow.ok
  %4 = call i32 (ptr, ...) @printf(ptr @fmt, i32 %add)
  %5 = call i32 (ptr, ...) @printf(ptr @nl)
  %6 = call { i32, i1 } @llvm.sadd.with.overflow.i32(i32 2, i32 3)
  %add4 = extractvalue { i32, i1 } %6, 0
  %overflow5 = extractvalue { i32, i1 } %6, 1
  br i1 %overflow5, label %overflow.trap6, label %overflow.ok7

overflow.trap6:                                   ; preds = %overflow.ok3
  %7 = call i32 @write(i32 2, ptr @overflow.msg.2, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok7:                                     ; preds = %overflow.ok3
  %8 = call { i32, i1 } @llvm.smul.with.overflow.i32(i32 %add4, i32 4)
  %mul8 = extractvalue { i32, i1 } %8, 0
  %overflow9 = extractvalue { i32, i1 } %8, 1
  br i1 %overflow9, label %overflow.trap10, label %overflow.ok11

overflow.trap10:                                  ; preds = %overflow.ok7
  %9 = call i32 @write(i32 2, ptr @overflow.msg.3, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok11:                                    ; preds = %overflow.ok7
  %10 = call i32 (ptr, ...) @printf(ptr @fmt.4, i32 %mul8)
  %11 = call i32 (ptr, ...) @printf(ptr @nl.5)
  %12 = call { i32, i1 } @llvm.sadd.with.overflow.i32(i32 10, i32 5)
  %add12 = extractvalue { i32, i1 } %12, 0
  %overflow13 = extractvalue { i32, i1 } %12, 1
  br i1 %overflow13, label %overflow.trap14, label %overflow.ok15

overflow.trap14:                                  ; preds = %overflow.ok11
  %13 = call i32 @write(i32 2, ptr @overflow.msg.6, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok15:                                    ; preds = %overflow.ok11
  %14 = call i32 (ptr, ...) @printf(ptr @fmt.7, i32 %add12)
  %15 = call i32 (ptr, ...) @printf(ptr @nl.8)
  %16 = call i32 (ptr, ...) @printf(ptr @fmt.9, i32 2)
  %17 = call i32 (ptr, ...) @printf(ptr @nl.10)
  ret i32 0
}

declare i32 @printf(ptr, ...)

; Function Attrs: nocallback nocreateundeforpoison nofree nosync nounwind speculatable willreturn memory(none)
declare { i32, i1 } @llvm.smul.with.overflow.i32(i32, i32) #0

declare i32 @write(i32, ptr, i32)

declare void @_exit(i32)

; Function Attrs: nocallback nocreateundeforpoison nofree nosync nounwind speculatable willreturn memory(none)
declare { i32, i1 } @llvm.sadd.with.overflow.i32(i32, i32) #0

attributes #0 = { nocallback nocreateundeforpoison nofree nosync nounwind speculatable willreturn memory(none) }

