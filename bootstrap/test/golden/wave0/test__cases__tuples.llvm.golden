; ModuleID = '<with_module>'
source_filename = "<source>"
target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-n32:64-S128-Fn32"
target triple = "arm64-apple-darwin25.2.0"

@overflow.msg = private unnamed_addr constant [33 x i8] c"runtime panic: integer overflow\0A\00", align 1

define { i32, i32 } @swap(i32 %0, i32 %1) {
entry:
  %2 = alloca i32, align 4
  store i32 %0, ptr %2, align 4
  %3 = alloca i32, align 4
  store i32 %1, ptr %3, align 4
  %4 = load i32, ptr %3, align 4
  %5 = load i32, ptr %2, align 4
  %tuple = alloca { i32, i32 }, align 8
  %6 = getelementptr { i32, i32 }, ptr %tuple, i32 0, i32 0
  store i32 %4, ptr %6, align 4
  %7 = getelementptr { i32, i32 }, ptr %tuple, i32 0, i32 1
  store i32 %5, ptr %7, align 4
  %tuple.val = load { i32, i32 }, ptr %tuple, align 4
  ret { i32, i32 } %tuple.val
}

define i32 @main() {
entry:
  %tuple = alloca { i32, i32 }, align 8
  %0 = getelementptr { i32, i32 }, ptr %tuple, i32 0, i32 0
  store i32 10, ptr %0, align 4
  %1 = getelementptr { i32, i32 }, ptr %tuple, i32 0, i32 1
  store i32 32, ptr %1, align 4
  %tuple.val = load { i32, i32 }, ptr %tuple, align 4
  %2 = alloca { i32, i32 }, align 8
  store { i32, i32 } %tuple.val, ptr %2, align 4
  %3 = getelementptr inbounds nuw { i32, i32 }, ptr %2, i32 0, i32 0
  %tuple.elem = load i32, ptr %3, align 4
  %4 = alloca i32, align 4
  store i32 %tuple.elem, ptr %4, align 4
  %5 = getelementptr inbounds nuw { i32, i32 }, ptr %2, i32 0, i32 1
  %tuple.elem1 = load i32, ptr %5, align 4
  %6 = alloca i32, align 4
  store i32 %tuple.elem1, ptr %6, align 4
  %7 = load i32, ptr %4, align 4
  %8 = load i32, ptr %6, align 4
  %9 = call { i32, i1 } @llvm.sadd.with.overflow.i32(i32 %7, i32 %8)
  %add = extractvalue { i32, i1 } %9, 0
  %overflow = extractvalue { i32, i1 } %9, 1
  br i1 %overflow, label %overflow.trap, label %overflow.ok

overflow.trap:                                    ; preds = %entry
  %10 = call i32 @write(i32 2, ptr @overflow.msg, i32 33)
  call void @_exit(i32 134)
  unreachable

overflow.ok:                                      ; preds = %entry
  %eq = icmp eq i32 %add, 42
  br i1 %eq, label %assert.ok, label %assert.fail

assert.fail:                                      ; preds = %overflow.ok
  call void @_exit(i32 134)
  unreachable

assert.ok:                                        ; preds = %overflow.ok
  ret i32 0
}

; Function Attrs: nocallback nocreateundeforpoison nofree nosync nounwind speculatable willreturn memory(none)
declare { i32, i1 } @llvm.sadd.with.overflow.i32(i32, i32) #0

declare i32 @write(i32, ptr, i32)

declare void @_exit(i32)

attributes #0 = { nocallback nocreateundeforpoison nofree nosync nounwind speculatable willreturn memory(none) }

