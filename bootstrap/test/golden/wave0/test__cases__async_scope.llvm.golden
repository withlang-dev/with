; ModuleID = '<with_module>'
source_filename = "<source>"
target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-n32:64-S128-Fn32"
target triple = "arm64-apple-darwin25.2.0"

declare void @with_runtime_init()

declare void @with_runtime_run()

declare void @with_runtime_shutdown()

declare i32 @with_fiber_spawn(ptr, ptr)

declare i64 @with_fiber_await(i32)

declare i32 @with_fiber_cancel(i32)

declare void @with_fiber_set_result(i64)

declare void @with_fiber_yield()

define i32 @work_async() {
entry:
  ret i32 1
}

define void @work_fiber(ptr %0) {
entry:
  %1 = call i32 @work_async()
  %task.res.sext = sext i32 %1 to i64
  call void @with_fiber_set_result(i64 %task.res.sext)
  ret void
}

define i32 @work() {
entry:
  %args = call ptr @malloc(i64 ptrtoint (ptr getelementptr ({}, ptr null, i32 1) to i64))
  %task = call i32 @with_fiber_spawn(ptr @work_fiber, ptr %args)
  ret i32 %task
}

define i32 @main_user() {
entry:
  %call = call i32 @work()
  %0 = call i32 @with_fiber_cancel(i32 %call)
  %1 = call i64 @with_fiber_await(i32 %call)
  ret i32 0
}

declare ptr @malloc(i64)

define i32 @main() {
entry:
  call void @with_runtime_init()
  %user.result = call i32 @main_user()
  call void @with_runtime_run()
  call void @with_runtime_shutdown()
  ret i32 %user.result
}

