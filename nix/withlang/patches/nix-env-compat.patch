+
+unsafe fn add_cimport_isystem_path(path: str) -> i32:
+    if g_cimport_isystem_count >= 64 or path.len() <= 0:
+        return 0
+    let buf = with_alloc(path.len() + 1)
+    if buf as i64 == 0:
+        return 0
+    let sp = str_data_ptr(path)
+    with_memcpy(buf, sp, path.len())
+    *((buf as i64 + path.len()) as *mut u8) = 0
+    g_cimport_isystem_paths[g_cimport_isystem_count as i64] = buf
+    g_cimport_isystem_count = g_cimport_isystem_count + 1
+    0
+
+unsafe fn load_cimport_isystem_paths():
+    if g_cimport_isystem_loaded != 0:
+        return
+    g_cimport_isystem_loaded = 1
+    let value = with_getenv_str("WITH_CIMPORT_ISYSTEM")
+    if value.len() == 0:
+        return
+    var start = 0
+    let value_len = value.len() as i32
+    for i in 0..(value_len + 1):
+        let at_end = i == value_len
+        if at_end or value.byte_at(i as i64) == 58:
+            if i > start:
+                let _ = add_cimport_isystem_path(value.slice(start as i64, i as i64))
+            start = i + 1
+
+unsafe fn append_cimport_isystem_args(args: *mut *const u8, nargs: i32, max_args: i32) -> i32:
