+    var dir = raw_dir
+    while dir.len() > 0 and dir.byte_at(dir.len() - 1) == 47:
+        dir = dir.slice(0, dir.len() - 1)
+    if dir.len() == 0:
+        return false
+    if not ci_starts_with(loc, dir):
+        return false
+    if loc.len() == dir.len():
+        return true
+    let next = loc.byte_at(dir.len())
+    next == 47 or next == 92 or next == 58
+
