+unsafe fn bridge_tmp_dir() -> str:
+    let with_tmp = with_getenv_str("WITH_TMPDIR")
+    if with_tmp.len() > 0:
+        return with_tmp
+    let tmpdir = with_getenv_str("TMPDIR")
+    if tmpdir.len() > 0:
+        return tmpdir
+    let temp = with_getenv_str("TEMP")
+    if temp.len() > 0:
