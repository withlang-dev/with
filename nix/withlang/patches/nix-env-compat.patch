+    "/tmp"
+
+unsafe fn tmp_template_to_buf(buf: *mut u8, cap: i64, name: str):
+    if cap <= 0:
+        return
+    let dir = bridge_tmp_dir()
+    let path = if dir.ends_with("/"): dir ++ name else: dir ++ "/" ++ name
+    let data = str_data_ptr(path)
+    var i: i64 = 0
+    while i < path.len() and i < cap - 1:
+        *((buf as i64 + i) as *mut u8) = *((data as i64 + i) as *const u8)
+        i = i + 1
